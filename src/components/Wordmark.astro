---
/**
 * Mimou brand mark.
 *   variant="mark" (default): text-only, MIMOU with a heart inside the O.
 *                             Same typographic system as the full logo.
 *                             Use in header, mobile nav, tight UI.
 *   variant="full":           the actual circular brand logo (PNG).
 *                             Use in footer or hero-adjacent large surfaces.
 *   compact:                  hides the subtitle row on the mark variant.
 *   color:                    overrides the ink color on the mark variant.
 */
interface Props {
  variant?: 'mark' | 'full';
  compact?: boolean;
  color?: string;
}
import { asset } from '../data/config';
const { variant = 'mark', compact = false, color } = Astro.props;
const inkStyle = color ? `color: ${color};` : '';
---
{variant === 'full' ? (
  <a href="#top" class="brandmark brandmark--full" aria-label="Mimou Presentes e Cestas">
    <img
      src={asset('/img/logo-mimou.png')}
      alt="Mimou Presentes e Cestas"
      width="640"
      height="640"
      loading="lazy"
      decoding="async"
    />
  </a>
) : (
  <a href="#top" class="brandmark brandmark--mark" style={inkStyle} aria-label="Mimou Presentes e Cestas">
    <span class="brandmark__name" aria-hidden="true">
      <span>M</span><span>I</span><span>M</span><span class="brandmark__o">O<svg class="brandmark__heart" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 20.5s-7-4.6-9.2-9.2C1 7.4 3.4 4 6.9 4c2 0 3.7 1.1 4.6 2.7l.5.9.5-.9C13.4 5.1 15.1 4 17.1 4c3.5 0 5.9 3.4 4.1 7.3C19 15.9 12 20.5 12 20.5Z"/></svg></span><span>U</span>
    </span>
    <span class="brandmark__sr">Mimou</span>
    {!compact && (
      <span class="brandmark__sub" aria-hidden="true">Cestas, Chocolates &amp; Pelúcias</span>
    )}
  </a>
)}

<style>
  .brandmark {
    display: inline-flex;
    text-decoration: none;
    color: inherit;
  }

  /* ---------- Full illustrated logo ---------- */
  .brandmark--full {
    display: block;
    width: clamp(140px, 22vw, 200px);
    aspect-ratio: 1 / 1;
    line-height: 0;
  }
  .brandmark--full img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* ---------- Text mark (tight spots) ---------- */
  .brandmark--mark {
    flex-direction: column;
    align-items: center;
    gap: 6px;
    line-height: 1;
    padding: 4px 12px;
  }
  .brandmark__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .brandmark__name {
    display: inline-flex;
    align-items: baseline;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 28px;
    letter-spacing: 0.18em;
    color: var(--color-cocoa-700);
  }
  .brandmark__name > span {
    display: inline-block;
  }
  /* The letter O carries a small heart, echoing the master logo. */
  .brandmark__o {
    position: relative;
  }
  .brandmark__heart {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 40%;
    height: 40%;
    transform: translate(-50%, -50%);
    color: var(--color-blush-400);
    pointer-events: none;
  }
  .brandmark__sub {
    font-family: var(--font-body);
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-cocoa-500);
    opacity: 0.9;
  }

  @media (min-width: 768px) {
    .brandmark__name { font-size: 32px; }
    .brandmark__sub  { font-size: 9px; }
  }
</style>
