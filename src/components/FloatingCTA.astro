---
import { whatsappLink } from '../data/config';
const href = whatsappLink('Olá, Mimou! 🎁');
---
<a
  class="float-cta"
  href={href}
  target="_blank"
  rel="noopener"
  aria-label="Abrir WhatsApp"
>
  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20.5 3.5A11 11 0 0 0 3.5 17.9L2 22l4.3-1.4A11 11 0 1 0 20.5 3.5Z" />
    <path d="M8 10.5c.5 2 2 3.5 4 4.5l1.5-1.5c.3-.3.7-.4 1-.3l3 1a.6.6 0 0 1 .4.7c-.4 2-2.3 3.3-4.3 3-3.6-.7-6.6-3.7-7.3-7.3-.2-2 1-3.9 3-4.3a.6.6 0 0 1 .7.4l1 3c.1.3 0 .7-.3 1L8 10.5Z" />
  </svg>
  <span>Encomendar</span>
</a>

<script>
  const cta = document.querySelector('.float-cta') as HTMLAnchorElement;
  const showObserver = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) cta.classList.add('is-visible');
        else cta.classList.remove('is-visible');
      }
    },
    { threshold: 0 }
  );
  const hero = document.querySelector('.hero');
  if (hero) showObserver.observe(hero);
</script>
