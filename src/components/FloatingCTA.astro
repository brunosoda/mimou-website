---
import { whatsappLink } from '../data/config';
const defaultHref = whatsappLink('Olá, Mimou! Gostaria de saber mais sobre os presentes.');
---
<a
  id="float-cta"
  class="float-cta"
  href={defaultHref}
  target="_blank"
  rel="noopener"
  aria-label="Encomendar pelo WhatsApp"
>
  <span class="float-cta__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.5 3.5A11 11 0 0 0 3.5 17.9L2 22l4.3-1.4A11 11 0 1 0 20.5 3.5Z" />
      <path d="M8 10.5c.5 2 2 3.5 4 4.5l1.5-1.5c.3-.3.7-.4 1-.3l3 1a.6.6 0 0 1 .4.7c-.4 2-2.3 3.3-4.3 3-3.6-.7-6.6-3.7-7.3-7.3-.2-2 1-3.9 3-4.3a.6.6 0 0 1 .7.4l1 3c.1.3 0 .7-.3 1L8 10.5Z" />
    </svg>
  </span>
  <span class="float-cta__label">
    <span class="float-cta__eyebrow">Encomendar</span>
    <span class="float-cta__title" id="float-cta-title">Pelo WhatsApp</span>
  </span>
</a>

<script>
  // Floating CTA that morphs its label to the product currently in view.
  const cta = document.getElementById('float-cta') as HTMLAnchorElement | null;
  const titleEl = document.getElementById('float-cta-title');
  if (cta && titleEl) {
    const defaultHref = cta.href;
    const defaultTitle = titleEl.textContent ?? 'Pelo WhatsApp';
    let currentSlug: string | null = null;

    // Show after scrolling past the hero
    const showObserver = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) cta.classList.add('is-visible');
          else cta.classList.remove('is-visible');
        }
      },
      { threshold: 0 }
    );
    const hero = document.querySelector('.hero');
    if (hero) showObserver.observe(hero);

    // Track the product card most-visible in viewport
    const cards = document.querySelectorAll<HTMLElement>('[data-product-slug]');
    const visible = new Map<Element, number>();

    const cardObserver = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.set(e.target, e.intersectionRatio);
          else visible.delete(e.target);
        }
        // Pick the target with the highest ratio
        let best: HTMLElement | null = null;
        let bestRatio = 0;
        for (const [el, r] of visible) {
          if (r > bestRatio) {
            bestRatio = r;
            best = el as HTMLElement;
          }
        }
        if (best) {
          const slug = best.dataset.productSlug;
          const name = best.dataset.productName;
          if (slug && slug !== currentSlug && name) {
            currentSlug = slug;
            titleEl.classList.add('is-changing');
            setTimeout(() => {
              titleEl.textContent = name;
              titleEl.classList.remove('is-changing');
            }, 200);
            const linkedCta = best.querySelector<HTMLAnchorElement>('.card__cta');
            if (linkedCta) cta.href = linkedCta.href;
          }
        } else if (currentSlug !== null) {
          currentSlug = null;
          titleEl.classList.add('is-changing');
          setTimeout(() => {
            titleEl.textContent = defaultTitle;
            titleEl.classList.remove('is-changing');
          }, 200);
          cta.href = defaultHref;
        }
      },
      {
        threshold: [0.25, 0.5, 0.75],
        rootMargin: '-25% 0px -25% 0px',
      }
    );
    cards.forEach((c) => cardObserver.observe(c));
  }
</script>
