---
const values = [
  {
    title: 'Feito com carinho',
    body: 'Cada presente é montado à mão, item por item, com atenção aos detalhes.',
    icon: 'gift',
  },
  {
    title: 'Detalhes que encantam',
    body: 'Da embalagem ao laço, tudo escolhido para surpreender quem recebe.',
    icon: 'leaf',
  },
  {
    title: 'Entrega com afeto',
    body: 'Entregamos em toda São Paulo capital com pontualidade e cuidado.',
    icon: 'bike',
  },
  {
    title: 'Inspirações únicas',
    body: 'Criações exclusivas para momentos que merecem ser lembrados.',
    icon: 'flower',
  },
];
---
<section class="values surface-cream" aria-label="Nossos diferenciais">
  <div class="values__inner">
    {values.map((v, i) => (
      <div class="values__item" data-reveal style={`--reveal-delay: ${i * 90}ms`}>
        <span class="values__icon" aria-hidden="true">
          {v.icon === 'gift' && (
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="12" width="22" height="15" rx="1"/>
              <path d="M3 12h26"/>
              <path d="M16 12v15"/>
              <path d="M16 12s-4-6-7-5-2 5 2 5"/>
              <path d="M16 12s4-6 7-5 2 5-2 5"/>
            </svg>
          )}
          {v.icon === 'leaf' && (
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 26c0-10 6-18 20-18 0 14-8 20-18 20"/>
              <path d="M8 26c4-4 8-6 14-8"/>
            </svg>
          )}
          {v.icon === 'bike' && (
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="8" cy="22" r="5"/>
              <circle cx="24" cy="22" r="5"/>
              <path d="M8 22l6-10h8l2-4h2"/>
              <path d="M14 12l4 10"/>
            </svg>
          )}
          {v.icon === 'flower' && (
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="16" cy="16" r="3"/>
              <path d="M16 13V6M16 19v7M13 16H6M19 16h7M11 11l-4-4M21 21l4 4M11 21l-4 4M21 11l4-4"/>
            </svg>
          )}
        </span>
        <div class="values__text">
          <h3 class="type-eyebrow values__title">{v.title}</h3>
          <p class="values__body">{v.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .values {
    padding: clamp(48px, 8vw, 96px) clamp(20px, 4vw, 40px);
    border-bottom: 1px solid color-mix(in oklab, var(--color-cocoa-500) 8%, transparent);
  }
  .values__inner {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: clamp(28px, 4vw, 56px);
  }
  .values__item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    color: var(--color-cocoa-700);
  }
  .values__icon {
    flex-shrink: 0;
    color: var(--color-cocoa-500);
    opacity: 0.85;
    margin-top: 2px;
  }
  .values__icon svg { width: 30px; height: 30px; }
  .values__title {
    color: var(--color-cocoa-900);
    margin-bottom: 8px;
  }
  .values__body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-cocoa-700);
    opacity: 0.85;
  }
</style>
