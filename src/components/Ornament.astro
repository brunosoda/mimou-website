---
interface Props {
  variant?: 'ribbon' | 'sprig' | 'diamond';
  class?: string;
}
const { variant = 'ribbon', class: klass = '' } = Astro.props;
---
{variant === 'ribbon' && (
  <span class={`ornament ${klass}`} aria-hidden="true">
    <svg viewBox="0 0 32 20" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
      <path d="M4 10 C 10 4, 14 4, 16 10 C 18 4, 22 4, 28 10 C 22 16, 18 16, 16 10 C 14 16, 10 16, 4 10 Z" />
      <circle cx="16" cy="10" r="0.9" fill="currentColor" />
    </svg>
  </span>
)}
{variant === 'sprig' && (
  <span class={`ornament ${klass}`} aria-hidden="true">
    <svg viewBox="0 0 40 24" fill="none" stroke="currentColor" stroke-width="0.9" stroke-linecap="round">
      <path d="M4 12 Q 20 4, 36 12" />
      <path d="M10 10 Q 12 6, 14 8" />
      <path d="M18 8 Q 20 4, 22 6" />
      <path d="M26 8 Q 28 4, 30 6" />
      <path d="M10 14 Q 12 18, 14 16" />
      <path d="M18 16 Q 20 20, 22 18" />
      <path d="M26 16 Q 28 20, 30 18" />
    </svg>
  </span>
)}
{variant === 'diamond' && (
  <span class={`ornament ${klass}`} aria-hidden="true">
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
      <path d="M10 3 L 15 10 L 10 17 L 5 10 Z" />
      <circle cx="10" cy="10" r="1.4" fill="currentColor" opacity="0.5" />
    </svg>
  </span>
)}
