---
import Wordmark from './Wordmark.astro';
import { brand, whatsappLink } from '../data/config';
---
<footer class="foot surface-forest">
  <div class="foot__inner">
    <div class="foot__mark">
      <Wordmark variant="full" />
      <p class="foot__tag font-script">{brand.tagline}</p>
    </div>

    <div class="foot__cols">
      <div class="foot__col">
        <h4 class="type-eyebrow foot__col-title">Encomendas</h4>
        <a href={whatsappLink('Olá, Mimou! Gostaria de encomendar um presente.')} target="_blank" rel="noopener" class="foot__link">
          WhatsApp {brand.whatsappDisplay}
        </a>
        <a href={`https://instagram.com/${brand.instagram}`} target="_blank" rel="noopener" class="foot__link">
          @{brand.instagram}
        </a>
        <a href={`mailto:${brand.email}`} class="foot__link">{brand.email}</a>
      </div>

      <div class="foot__col">
        <h4 class="type-eyebrow foot__col-title">Atendimento</h4>
        <p class="foot__text">{brand.hours}</p>
        <p class="foot__text">São Paulo — SP</p>
        <p class="foot__text foot__text--muted">Entrega e retirada combinadas por WhatsApp.</p>
      </div>

      <div class="foot__col">
        <h4 class="type-eyebrow foot__col-title">Explore</h4>
        <a href="#ofertas" class="foot__link">Ofertas</a>
        <a href="#buques" class="foot__link">Buquês</a>
        <a href="#cestas" class="foot__link">Cestas</a>
        <a href="#signature" class="foot__link">Mimou Signature</a>
        <a href="#depoimentos" class="foot__link">Depoimentos</a>
        <a href="#como-funciona" class="foot__link">Como funciona</a>
        <a href="#sobre" class="foot__link">Sobre nós</a>
      </div>
    </div>
  </div>

  <div class="foot__base">
    <span class="foot__legal">
      © {new Date().getFullYear()} {brand.fullName} · Feito com carinho em São Paulo.
    </span>
    <span class="foot__legal foot__legal--muted">
      CNPJ e endereço serão atualizados em breve.
    </span>
  </div>
</footer>

<style>
  .foot { padding: clamp(64px, 10vw, 120px) clamp(20px, 4vw, 40px) 32px; }
  .foot__inner {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
  }
  @media (min-width: 900px) {
    .foot__inner { grid-template-columns: 1fr 1.4fr; align-items: start; }
  }
  .foot__mark {
    display: flex;
    flex-direction: column;
    gap: 20px;
    color: var(--color-cream-50);
  }
  .foot__tag {
    font-size: 22px;
    color: var(--color-blush-200);
    opacity: 0.85;
  }
  .foot__cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 40px;
    color: var(--color-cream-100);
  }
  .foot__col-title {
    color: var(--color-gold-400);
    margin-bottom: 18px;
    display: block;
  }
  .foot__link,
  .foot__text {
    display: block;
    color: color-mix(in oklab, var(--color-cream-100) 90%, transparent);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.7;
    transition: color 200ms ease;
  }
  .foot__link:hover { color: var(--color-cream-50); text-decoration: underline; text-underline-offset: 4px; }
  .foot__text--muted, .foot__legal--muted { opacity: 0.55; font-size: 12px; margin-top: 8px; }
  .foot__base {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 64px auto 0;
    padding-top: 24px;
    border-top: 1px solid color-mix(in oklab, var(--color-cream-100) 18%, transparent);
    display: flex;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    color: color-mix(in oklab, var(--color-cream-100) 65%, transparent);
    font-size: 12px;
    letter-spacing: 0.04em;
  }
</style>
