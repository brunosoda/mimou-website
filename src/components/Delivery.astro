---
import { brand } from '../data/config';
---
<section class="delivery surface-forest" id="entrega">
  <div class="delivery__inner">
    <div class="delivery__intro">
      <span class="type-eyebrow delivery__kicker" data-reveal="fade">Entrega em São Paulo</span>
      <h2 class="type-display-md delivery__title" data-reveal="up-lg" style="--reveal-delay: 100ms">
        Levamos seu presente <em>onde ele precisa chegar</em>.
      </h2>
      <p class="type-body delivery__body" data-reveal style="--reveal-delay: 220ms">
        Entregamos em toda a capital, com combinação prévia por WhatsApp. Consulte o valor
        do frete para o seu bairro — para alguns endereços, retirada no estúdio também é possível.
      </p>
    </div>

    <ul class="delivery__list" data-reveal style="--reveal-delay: 300ms">
      {brand.neighborhoods.map((n) => (
        <li class="delivery__item">
          <svg viewBox="0 0 12 12" width="8" height="8" fill="currentColor" aria-hidden="true">
            <circle cx="6" cy="6" r="3"/>
          </svg>
          <span>{n}</span>
        </li>
      ))}
      <li class="delivery__item delivery__item--more">
        <span>e demais bairros de São Paulo capital</span>
      </li>
    </ul>
  </div>
</section>

<style>
  .delivery {
    padding: clamp(64px, 10vw, 128px) clamp(20px, 4vw, 40px);
  }
  .delivery__inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(40px, 5vw, 80px);
  }
  @media (min-width: 900px) {
    .delivery__inner { grid-template-columns: 1fr 1.1fr; align-items: start; }
  }
  .delivery__kicker { color: var(--color-gold-400); }
  .delivery__title { color: var(--color-cream-50); margin-top: 18px; }
  .delivery__title em { color: var(--color-blush-200); font-style: italic; font-weight: 400; }
  .delivery__body {
    color: color-mix(in oklab, var(--color-cream-100) 92%, transparent);
    margin-top: 20px;
    max-width: 40ch;
  }
  .delivery__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px 20px;
    padding-top: 8px;
    border-top: 1px solid color-mix(in oklab, var(--color-cream-100) 20%, transparent);
    padding-top: 32px;
  }
  .delivery__item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: color-mix(in oklab, var(--color-cream-100) 85%, transparent);
  }
  .delivery__item svg { color: var(--color-gold-400); flex-shrink: 0; }
  .delivery__item--more {
    grid-column: 1 / -1;
    padding-top: 20px;
    border-top: 1px solid color-mix(in oklab, var(--color-cream-100) 15%, transparent);
    font-style: italic;
    opacity: 0.7;
    color: var(--color-blush-200);
  }
</style>
