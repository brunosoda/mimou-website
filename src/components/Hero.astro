---
import Ornament from './Ornament.astro';
import { whatsappLink, asset } from '../data/config';
---
<section class="hero surface-forest" id="top">
  <!-- Decorative cherry blossom SVG in the corners -->
  <svg class="hero__blossom hero__blossom--tl" viewBox="0 0 320 320" aria-hidden="true">
    <g fill="none" stroke="#E8CDC7" stroke-width="0.9" opacity="0.55">
      <path d="M20 40 Q 90 30, 160 80 Q 210 110, 280 140" />
      <path d="M40 80 Q 100 100, 140 140" />
    </g>
    <g fill="#E8CDC7" opacity="0.9">
      <g transform="translate(60 70)"><circle r="6" opacity="0.5"/><circle cx="4" cy="-4" r="4"/><circle cx="-4" cy="-4" r="4"/><circle cx="4" cy="4" r="4"/><circle cx="-4" cy="4" r="4"/><circle r="1.5" fill="#A6884D"/></g>
      <g transform="translate(140 130)"><circle r="7" opacity="0.5"/><circle cx="5" cy="-5" r="5"/><circle cx="-5" cy="-5" r="5"/><circle cx="5" cy="5" r="5"/><circle cx="-5" cy="5" r="5"/><circle r="2" fill="#A6884D"/></g>
      <g transform="translate(220 110)"><circle r="5" opacity="0.5"/><circle cx="3.5" cy="-3.5" r="3.5"/><circle cx="-3.5" cy="-3.5" r="3.5"/><circle cx="3.5" cy="3.5" r="3.5"/><circle cx="-3.5" cy="3.5" r="3.5"/></g>
      <g transform="translate(90 150)"><circle r="4" opacity="0.5"/><circle cx="3" cy="-3" r="3"/><circle cx="-3" cy="-3" r="3"/><circle cx="3" cy="3" r="3"/><circle cx="-3" cy="3" r="3"/></g>
    </g>
  </svg>

  <svg class="hero__blossom hero__blossom--br" viewBox="0 0 320 320" aria-hidden="true">
    <g fill="none" stroke="#E8CDC7" stroke-width="0.9" opacity="0.45">
      <path d="M40 280 Q 120 260, 200 220 Q 260 190, 300 150" />
    </g>
    <g fill="#E8CDC7" opacity="0.85">
      <g transform="translate(120 240)"><circle r="6" opacity="0.5"/><circle cx="4" cy="-4" r="4"/><circle cx="-4" cy="-4" r="4"/><circle cx="4" cy="4" r="4"/><circle cx="-4" cy="4" r="4"/></g>
      <g transform="translate(220 200)"><circle r="5" opacity="0.5"/><circle cx="3.5" cy="-3.5" r="3.5"/><circle cx="-3.5" cy="-3.5" r="3.5"/><circle cx="3.5" cy="3.5" r="3.5"/><circle cx="-3.5" cy="3.5" r="3.5"/></g>
    </g>
  </svg>

  <div class="hero__inner">
    <div class="hero__copy">
      <span class="type-eyebrow hero__eyebrow" data-reveal="fade">
        <span class="hero__eyebrow-dash" aria-hidden="true"></span>
        Presentes artesanais · São Paulo
      </span>
      <h1 class="type-display-xl hero__title" data-reveal="up-lg" style="--reveal-delay: 100ms">
        Presentes que<br />
        <em class="hero__title-em">contam histórias</em>.
      </h1>

      <span class="hero__divider" data-reveal="fade" style="--reveal-delay: 200ms">
        <Ornament variant="ribbon" />
      </span>

      <p class="type-lead hero__lead" data-reveal style="--reveal-delay: 280ms">
        Delicadeza em cada detalhe,<br />
        carinho em cada entrega.
      </p>

      <div class="hero__ctas" data-reveal style="--reveal-delay: 360ms">
        <a href="#ofertas" class="btn btn-cream">Conheça os presentes</a>
        <a
          href={whatsappLink('Olá! Vi o site da Mimou e gostaria de encomendar um presente.')}
          target="_blank"
          rel="noopener"
          class="btn btn-outline-cream"
        >
          Falar no WhatsApp
        </a>
      </div>

      <p class="hero__signature font-script" data-reveal style="--reveal-delay: 480ms">
        Feito à mão, entregue com afeto.
      </p>
    </div>

    <div class="hero__stage">
      <!-- Atelier arch: soft blush shape behind the featured product, echoes a Parisian vitrine -->
      <svg class="hero__arch" viewBox="0 0 400 500" preserveAspectRatio="none" aria-hidden="true">
        <defs>
          <linearGradient id="archFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"  stop-color="#F1D9D2" />
            <stop offset="100%" stop-color="#E8CDC7" />
          </linearGradient>
        </defs>
        <path d="M 20 500 L 20 200 A 180 180 0 0 1 380 200 L 380 500 Z" fill="url(#archFill)"/>
        <path d="M 20 500 L 20 200 A 180 180 0 0 1 380 200 L 380 500" fill="none" stroke="#C4A46E" stroke-width="1" opacity="0.35"/>
      </svg>

      <div class="hero__frame">
        <img
          src={asset('/products/cesta-aniversario-hero.png')}
          alt="Cesta de aniversário Mimou com ursinho, balão de coração e chocolates"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero__frame-tag">
          <span class="type-eyebrow">Destaque</span>
          <span class="hero__frame-name font-display">Cesta de Aniversário</span>
        </div>
      </div>

      <div class="hero__stamp" aria-hidden="true">
        <svg viewBox="0 0 100 100" fill="none">
          <circle cx="50" cy="50" r="46" stroke="#C4A46E" stroke-width="0.8" opacity="0.7"/>
          <circle cx="50" cy="50" r="40" stroke="#C4A46E" stroke-width="0.5" opacity="0.5"/>
          <text x="50" y="47" font-family="Cormorant Garamond" font-size="9" fill="#F5EBD6" text-anchor="middle" opacity="0.85">MIMOU · SP</text>
          <text x="50" y="58" font-family="Cormorant Garamond" font-size="6.5" fill="#C4A46E" text-anchor="middle" font-style="italic">depuis 2024</text>
        </svg>
      </div>
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span class="type-eyebrow">Deslize</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: clamp(64px, 10vh, 120px) clamp(20px, 4vw, 40px) clamp(80px, 12vh, 140px);
    min-height: min(92svh, 900px);
    overflow: hidden;
    isolation: isolate;
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero__inner {
      grid-template-columns: 1.05fr 1fr;
    }
  }
  .hero__blossom {
    position: absolute;
    width: min(60vw, 480px);
    height: min(60vw, 480px);
    pointer-events: none;
    z-index: 1;
  }
  .hero__blossom--tl { top: -80px; left: -80px; }
  .hero__blossom--br { bottom: -80px; right: -80px; }

  .hero__copy { color: var(--color-cream-100); }
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--color-gold-400);
    margin-bottom: 32px;
  }
  .hero__eyebrow-dash {
    width: 36px; height: 1px;
    background: currentColor;
    opacity: 0.6;
  }
  .hero__title {
    color: var(--color-cream-50);
  }
  .hero__title-em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-blush-200);
  }
  .hero__divider {
    display: inline-block;
    margin: 26px 0 22px;
    color: var(--color-gold-400);
  }
  .hero__lead {
    color: color-mix(in oklab, var(--color-cream-100) 92%, transparent);
    max-width: 42ch;
  }
  .hero__ctas {
    margin-top: 34px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .hero__signature {
    margin-top: 32px;
    color: var(--color-blush-200);
    opacity: 0.8;
    font-size: 20px;
  }

  /* Stage: atelier arch with product frame in front */
  .hero__stage {
    position: relative;
    aspect-ratio: 4 / 5;
    max-width: 520px;
    margin: 0 auto;
    width: 100%;
    /* Give the arch room to breathe on the sides + above */
    padding: 6% 8% 0;
    box-sizing: border-box;
  }

  /* The arch shape sits behind the product image */
  .hero__arch {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    filter: drop-shadow(0 30px 60px rgb(0 0 0 / 0.35));
    transform-origin: 50% 100%;
    animation: hero-arch-in 900ms cubic-bezier(0.22, 1, 0.36, 1) 200ms both;
  }

  /* Product image floats in front of the arch */
  .hero__frame {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 30px 60px -32px rgb(0 0 0 / 0.5);
    animation: hero-image-in 1100ms cubic-bezier(0.22, 1, 0.36, 1) 500ms both;
  }
  .hero__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(1.0) saturate(1.02);
    display: block;
  }
  .hero__frame-tag {
    position: absolute;
    left: 20px;
    bottom: 20px;
    padding: 12px 16px;
    background: color-mix(in oklab, var(--color-forest-900) 82%, transparent);
    backdrop-filter: blur(8px);
    color: var(--color-cream-100);
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-radius: 2px;
    animation: hero-tag-in 700ms cubic-bezier(0.22, 1, 0.36, 1) 950ms both;
  }
  .hero__frame-tag .type-eyebrow { color: var(--color-gold-400); }
  .hero__frame-name { font-size: 20px; letter-spacing: 0.01em; }

  .hero__stamp {
    position: absolute;
    right: -12px;
    top: -12px;
    width: 96px;
    height: 96px;
    z-index: 2;
    transform: rotate(-12deg);
    opacity: 0.85;
    animation: hero-stamp-in 800ms cubic-bezier(0.22, 1, 0.36, 1) 750ms both;
  }

  @keyframes hero-arch-in {
    0%   { opacity: 0; transform: scale(0.86); }
    100% { opacity: 1; transform: scale(1); }
  }
  @keyframes hero-image-in {
    0%   { opacity: 0; transform: translateY(48px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-tag-in {
    0%   { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-stamp-in {
    0%   { opacity: 0; transform: rotate(-24deg) scale(0.7); }
    100% { opacity: 0.85; transform: rotate(-12deg) scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__arch,
    .hero__frame,
    .hero__frame-tag,
    .hero__stamp { animation: none; opacity: 1; transform: none; }
    .hero__stamp { transform: rotate(-12deg); opacity: 0.85; }
  }

  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: var(--color-cream-200);
    opacity: 0.55;
    z-index: 2;
  }
  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: currentColor;
    animation: scroll-hint 2.4s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes scroll-hint {
    0%   { transform: scaleY(0.3); opacity: 0.2; }
    50%  { transform: scaleY(1);   opacity: 0.8; }
    100% { transform: scaleY(0.3); opacity: 0.2; transform-origin: bottom; }
  }
</style>
