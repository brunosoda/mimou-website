---
import Ornament from './Ornament.astro';
import { whatsappLink } from '../data/config';

const steps = [
  {
    title: 'Escolha o presente',
    body: 'Navegue pelo catálogo e escolha a cesta, o buquê ou o mimo ideal. Se quiser algo único, também montamos sob medida.',
  },
  {
    title: 'Combine pelo WhatsApp',
    body: 'Confirme o pedido, personalize os detalhes — cartãozinho, doces, cores — e combine data, endereço e horário da entrega.',
  },
  {
    title: 'Preparamos à mão',
    body: 'No dia da entrega, seu presente é montado item por item e embalado com todo o cuidado no nosso ateliê.',
  },
  {
    title: 'Entrega no momento certo',
    body: 'Levamos até o endereço combinado, no horário combinado — e avisamos você assim que o presente for entregue.',
  },
];

const midnightRules = [
  {
    title: 'Taxa adicional',
    body: 'A entrega à meia-noite tem um acréscimo no valor do frete, combinado no momento do pedido.',
  },
  {
    title: 'Até 30 minutos de espera',
    body: 'Nosso entregador aguarda até 30 minutos no endereço para o momento da surpresa acontecer.',
  },
  {
    title: 'Segunda tentativa pela manhã',
    body: 'Se não for possível entregar, fazemos uma nova tentativa na manhã seguinte, com nova taxa de entrega.',
  },
];
---
<section class="how surface-cream" id="como-funciona">
  <div class="how__inner">
    <header class="how__head">
      <span class="type-eyebrow how__kicker" data-reveal="fade">Do pedido à entrega</span>
      <h2 class="type-display-lg how__title" data-reveal="up-lg" style="--reveal-delay: 100ms">
        Como funciona
      </h2>
      <span class="how__ornament" data-reveal="fade" style="--reveal-delay: 200ms">
        <Ornament variant="ribbon" />
      </span>
    </header>

    <ol class="how__steps">
      {steps.map((s, i) => (
        <li class="how__step" data-reveal style={`--reveal-delay: ${i * 110}ms`}>
          <span class="how__step-num font-display" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="how__step-title font-display">{s.title}</h3>
          <p class="how__step-body">{s.body}</p>
        </li>
      ))}
    </ol>

    <aside class="how__midnight" data-reveal="scale" style="--reveal-delay: 150ms" aria-labelledby="midnight-title">
      <svg class="how__midnight-sky" viewBox="0 0 400 200" aria-hidden="true" preserveAspectRatio="xMaxYMin meet">
        <path
          d="M330 26 A 26 26 0 1 0 330 78 A 33 33 0 0 1 330 26 Z"
          fill="#F5EBD6"
          opacity="0.9"
        />
        <g fill="#C4A46E">
          <circle cx="250" cy="40" r="1.6"/>
          <circle cx="285" cy="95" r="1.2"/>
          <circle cx="360" cy="110" r="1.4"/>
          <circle cx="220" cy="80" r="1"/>
          <circle cx="310" cy="130" r="1.1"/>
          <path d="M265 62 l1.5 4 4 1.5 -4 1.5 -1.5 4 -1.5 -4 -4 -1.5 4 -1.5 Z" opacity="0.9"/>
        </g>
      </svg>

      <div class="how__midnight-content">
        <span class="type-eyebrow how__midnight-kicker">Para começar o dia especial</span>
        <h3 class="type-display-md how__midnight-title" id="midnight-title">
          Surpresa à <em>meia-noite</em>
        </h3>
        <p class="type-body how__midnight-lead">
          Quer surpreender alguém no primeiro minuto do aniversário? Entregamos o presente
          à meia-noite em ponto, com direito a todo o suspense. Assim funciona:
        </p>

        <ul class="how__midnight-rules">
          {midnightRules.map((r) => (
            <li class="how__midnight-rule">
              <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 10.5l4 4 8-9"/>
              </svg>
              <span>
                <strong>{r.title}.</strong> {r.body}
              </span>
            </li>
          ))}
        </ul>

        <a
          href={whatsappLink('Olá, Mimou! Quero encomendar uma surpresa à meia-noite. 🌙')}
          target="_blank"
          rel="noopener"
          class="btn btn-cream how__midnight-cta"
        >
          Quero uma surpresa à meia-noite
        </a>
      </div>
    </aside>
  </div>
</section>

<style>
  .how {
    padding: clamp(72px, 10vw, 128px) clamp(20px, 4vw, 40px);
    position: relative;
    isolation: isolate;
  }
  .how__inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
  }
  .how__head {
    text-align: center;
    margin-bottom: clamp(48px, 6vw, 80px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .how__kicker { color: var(--color-gold-500); }
  .how__title { color: var(--color-cocoa-900); }
  .how__ornament { color: var(--color-gold-500); opacity: 0.7; }

  .how__steps {
    list-style: none;
    margin: 0 0 clamp(56px, 7vw, 88px);
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(28px, 4vw, 40px);
    counter-reset: step;
  }
  @media (min-width: 640px)  { .how__steps { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (min-width: 1000px) { .how__steps { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

  .how__step {
    position: relative;
    padding-top: 18px;
    border-top: 1px solid color-mix(in oklab, var(--color-cocoa-500) 20%, transparent);
  }
  .how__step-num {
    display: block;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-gold-500);
    margin-bottom: 12px;
  }
  .how__step-title {
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-cocoa-900);
    margin-bottom: 10px;
  }
  .how__step-body {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-cocoa-700);
    opacity: 0.9;
    max-width: 34ch;
  }

  /* Midnight surprise — dark card, night-sky motif */
  .how__midnight {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background:
      radial-gradient(900px 400px at 85% -60px, #3A4636 0%, transparent 60%),
      linear-gradient(to bottom right, var(--color-forest-800), var(--color-forest-900));
    box-shadow: 0 40px 80px -40px rgb(26 33 24 / 0.55);
    border: 1px solid color-mix(in oklab, var(--color-gold-400) 25%, transparent);
  }
  .how__midnight-sky {
    position: absolute;
    top: 0;
    right: 0;
    width: min(60%, 420px);
    height: auto;
    pointer-events: none;
    opacity: 0.85;
  }
  .how__midnight-content {
    position: relative;
    z-index: 1;
    padding: clamp(32px, 5vw, 64px);
    max-width: 62ch;
  }
  .how__midnight-kicker {
    color: var(--color-gold-400);
    display: block;
    margin-bottom: 16px;
  }
  .how__midnight-title { color: var(--color-cream-50); }
  .how__midnight-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-blush-200);
  }
  .how__midnight-lead {
    color: color-mix(in oklab, var(--color-cream-100) 90%, transparent);
    margin-top: 14px;
  }
  .how__midnight-rules {
    list-style: none;
    margin: 26px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .how__midnight-rule {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 14px;
    line-height: 1.6;
    color: color-mix(in oklab, var(--color-cream-100) 85%, transparent);
  }
  .how__midnight-rule svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--color-gold-400);
  }
  .how__midnight-rule strong {
    color: var(--color-cream-50);
    font-weight: 600;
  }
  .how__midnight-cta { margin-top: 32px; }
</style>
