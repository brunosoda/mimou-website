---
import Wordmark from './Wordmark.astro';
import { brand, whatsappLink } from '../data/config';
const nav = [
  { label: 'Início',           href: '#top' },
  { label: 'Ofertas',          href: '#ofertas' },
  { label: 'Buquês',           href: '#buques' },
  { label: 'Cestas',           href: '#cestas' },
  { label: 'Mimou Signature',  href: '#signature' },
  { label: 'Sobre Nós',        href: '#sobre' },
];
---
<header class="site-header" id="site-header">
  <div class="site-header__inner">
    <nav class="site-header__nav" aria-label="Principal">
      {nav.map((item) => (
        <a href={item.href} class="site-header__link">{item.label}</a>
      ))}
    </nav>
    <div class="site-header__logo"><Wordmark /></div>
    <div class="site-header__actions">
      <a
        href={whatsappLink('Olá! Gostaria de saber mais sobre os presentes da Mimou.')}
        target="_blank"
        rel="noopener"
        class="site-header__icon"
        aria-label="WhatsApp"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.5 3.5A11 11 0 0 0 3.5 17.9L2 22l4.3-1.4A11 11 0 1 0 20.5 3.5Z" />
          <path d="M8 10.5c.5 2 2 3.5 4 4.5l1.5-1.5c.3-.3.7-.4 1-.3l3 1a.6.6 0 0 1 .4.7c-.4 2-2.3 3.3-4.3 3-3.6-.7-6.6-3.7-7.3-7.3-.2-2 1-3.9 3-4.3a.6.6 0 0 1 .7.4l1 3c.1.3 0 .7-.3 1L8 10.5Z" />
        </svg>
      </a>
      <a
        href={`https://instagram.com/${brand.instagram}`}
        target="_blank"
        rel="noopener"
        class="site-header__icon"
        aria-label="Instagram"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="5" />
          <circle cx="12" cy="12" r="4" />
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
        </svg>
      </a>
      <button class="site-header__menu" aria-label="Abrir menu" id="menu-toggle">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M3 7h18M3 12h18M3 17h18" />
        </svg>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Menu">
    {nav.map((item) => (
      <a href={item.href} class="mobile-nav__link">{item.label}</a>
    ))}
    <a
      href={whatsappLink('Olá! Gostaria de saber mais sobre os presentes da Mimou.')}
      target="_blank"
      rel="noopener"
      class="mobile-nav__whats"
    >
      Falar no WhatsApp
    </a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-cream-50) 92%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid color-mix(in oklab, var(--color-cocoa-500) 10%, transparent);
    transition: box-shadow 300ms ease, padding 400ms ease;
  }
  .site-header.is-scrolled {
    box-shadow: 0 8px 24px -18px rgb(60 40 20 / 0.35);
  }
  .site-header__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 22px clamp(20px, 4vw, 40px);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
    transition: padding 400ms ease;
  }
  .site-header.is-scrolled .site-header__inner { padding-block: 14px; }

  .site-header__nav {
    display: none;
    gap: 28px;
    color: var(--color-cocoa-900);
  }
  .site-header__link {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    opacity: 0.75;
    padding-bottom: 4px;
    border-bottom: 1px solid transparent;
    transition: opacity 200ms ease, border-color 200ms ease;
  }
  .site-header__link:hover {
    opacity: 1;
    border-bottom-color: var(--color-cocoa-700);
  }

  .site-header__logo {
    display: flex;
    justify-content: center;
    color: var(--color-cocoa-900);
  }

  .site-header__actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 8px;
    color: var(--color-cocoa-900);
  }
  .site-header__icon {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-pill);
    color: inherit;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 200ms ease, background 200ms ease;
  }
  .site-header__icon:hover {
    opacity: 1;
    background: color-mix(in oklab, var(--color-cocoa-500) 10%, transparent);
  }
  .site-header__menu {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    opacity: 0.85;
  }

  /* Mobile nav */
  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 8px clamp(20px, 4vw, 40px) 24px;
    border-top: 1px solid color-mix(in oklab, var(--color-cocoa-500) 10%, transparent);
  }
  .mobile-nav.is-open { display: flex; }
  .mobile-nav__link {
    padding: 14px 0;
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-cocoa-900);
    opacity: 0.8;
    border-bottom: 1px solid color-mix(in oklab, var(--color-cocoa-500) 8%, transparent);
  }
  .mobile-nav__whats {
    margin-top: 14px;
    background: #128C4E;
    color: white;
    text-decoration: none;
    padding: 14px 18px;
    text-align: center;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 12px;
    border-radius: 4px;
  }

  @media (min-width: 900px) {
    .site-header__nav { display: flex; }
    .site-header__menu { display: none; }
  }
</style>

<script>
  const header = document.getElementById('site-header')!;
  window.addEventListener(
    'scroll',
    () => {
      if (window.scrollY > 20) header.classList.add('is-scrolled');
      else header.classList.remove('is-scrolled');
    },
    { passive: true }
  );
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => nav?.classList.toggle('is-open'));
  nav?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => nav.classList.remove('is-open'))
  );
</script>
